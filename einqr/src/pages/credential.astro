---
import Layout from "../layouts/Layout.astro";
import pool from "../lib/db";

const session = Astro.cookies.get("session")?.value;

if (!session) {
  return Astro.redirect("/login");
}

// Obtener ID de usuario de la sesión (formato: user-ID)
const userId = session.replace("user-", "");

let user = null;

try {
  const [rows]: any = await pool.execute("SELECT * FROM users WHERE id = ?", [
    userId,
  ]);
  if (rows.length > 0) {
    user = rows[0];
  }
} catch (error) {
  console.error("Error al obtener usuario:", error);
}

// Si no existe el usuario, redirigir
if (!user) {
  return Astro.redirect("/login");
}

// Configuración de logos por empresa
const companyLogos: Record<string, string> = {
  Einsur:
    "https://prosime.com.mx/wp-content/uploads/2023/04/Einsur-Logo-300x100.png", // Placeholder o URL real
  Innova:
    "https://prosime.com.mx/wp-content/uploads/2023/04/Innova-Logo-300x100.png", // Placeholder o URL real
};

const userPhoto = `https://ui-avatars.com/api/?name=${encodeURIComponent(
  user.full_name,
)}&background=3b82f6&color=fff&size=200`;
---

<Layout title="Mi Credencial | Gafete Virtual">
  <div class="credential-container">
    <header class="header">
      <div class="header-content"></div>
      <a href="/login" class="logout-btn">Salir</a>
    </header>

    <main class="main-content">
      <!-- Tarjeta de Identificación -->
      <div class="id-card">
        <div class="card-top">
          <div class="company-badge-logo">
            <span class="company-name-text">{user.company || "Einsur"}</span>
          </div>
          <div class="security-seal"></div>
        </div>

        <div class="card-body">
          <div class="photo-container">
            <img src={userPhoto} alt="User Photo" id="user-photo" />
          </div>
          <div class="user-info">
            <h2>{user.full_name}</h2>
            <p class="role">{user.department || "Personal"}</p>
            <div class="details">
              <div class="detail-item">
                <span>ID</span>
                <p>{user.employee_id}</p>
              </div>
              <div class="detail-item">
                <span>Empresa</span>
                <p>{user.company || "Einsur"}</p>
              </div>
            </div>
          </div>
        </div>
        <!-- QR dentro del mismo cuadro -->
        <div class="qr-section">
          <div class="qr-container">
            <div id="qr-loader" class="loader"></div>
            <img
              id="qr-image"
              src=""
              alt="Dynamic QR Code"
              style="display: none;"
            />
            <div id="refresh-indicator" class="refresh-progress"></div>
          </div>
          <div class="countdown"></div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  .credential-container {
    min-height: 100vh;
    background: #0a0a0a;
    color: white;
    font-family: "Inter", system-ui, sans-serif;
    display: flex;
    flex-direction: column;
  }

  .header {
    padding: 16px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .header-content {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .status-indicator {
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    box-shadow: 0 0 10px #10b981;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
    100% {
      opacity: 1;
    }
  }

  .status-text {
    font-size: 0.75rem;
    color: #94a3b8;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .logout-btn {
    color: #ef4444;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .main-content {
    flex: 1;
    padding: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    max-width: 500px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }

  /* Estilos del Gafete */
  .id-card {
    width: 100%;
    background: linear-gradient(145deg, #1e293b, #0f172a);
    border-radius: 20px;
    padding: 24px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .id-card::before {
    content: "";
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.03) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .company-badge-logo {
    background: rgba(255, 255, 255, 0.1);
    padding: 8px 16px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .company-name-text {
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 1px;
    color: #3b82f6;
    text-transform: uppercase;
  }

  .security-seal {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, #ffd700, #b8860b);
    border-radius: 50%;
    opacity: 0.8;
    box-shadow: 0 0 15px rgba(255, 215, 0, 0.2);
  }

  .card-body {
    display: flex;
    gap: 20px;
    align-items: center;
    margin-bottom: 24px;
  }

  .photo-container {
    width: 100px;
    height: 100px;
    border-radius: 16px;
    overflow: hidden;
    border: 3px solid rgba(255, 255, 255, 0.1);
    background: #000;
    flex-shrink: 0;
  }

  .photo-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .user-info h2 {
    margin: 0 0 4px;
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
  }

  .role {
    margin: 0 0 16px;
    font-size: 0.875rem;
    color: #3b82f6;
    font-weight: 600;
  }

  .details {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 12px;
  }

  .detail-item span {
    font-size: 0.625rem;
    color: #64748b;
    text-transform: uppercase;
    font-weight: 700;
  }

  .detail-item p {
    margin: 2px 0 0;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #e2e8f0;
  }

  /* Estilos del QR */
  .qr-section {
    background: linear-gradient(145deg, #1a2433, #0f172a);
    color: white;
    padding: 24px;
    border-radius: 20px;
    margin-top: 24px;
    text-align: center;
    margin: 0 0 8px;
    font-size: 1.125rem;
  }

  .qr-section p {
    margin: 0 0 24px;
    font-size: 0.875rem;
    color: #94a3b8;
  }

  .qr-container {
    background: white;
    padding: 16px;
    border-radius: 24px;
    display: inline-block;
    position: relative;
    box-shadow: 0 10px 30px rgba(59, 130, 246, 0.2);
    width: 200px;
    height: 200px;
  }

  #qr-image {
    width: 100%;
    height: 100%;
  }

  .loader {
    width: 40px;
    height: 40px;
    border: 4px solid #f3f3f3;
    border-top: 4px solid #3b82f6;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    position: absolute;
    top: calc(50% - 20px);
    left: calc(50% - 20px);
  }

  @keyframes spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  .refresh-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 4px;
    background: #3b82f6;
    width: 0%;
    transition: width 1s linear;
  }

  .countdown {
    margin-top: 16px;
    font-size: 0.875rem;
    color: #64748b;
  }

  #timer {
    color: #3b82f6;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
</style>

<script>
  let timeLeft = 30;
  const timerElement = document.getElementById("timer");
  const qrImage = document.getElementById("qr-image") as HTMLImageElement;
  const qrLoader = document.getElementById("qr-loader");
  const progressBar = document.getElementById("refresh-indicator");

  async function updateQR() {
    qrLoader!.style.display = "block";
    qrImage.style.opacity = "0.5";

    try {
      const response = await fetch("/api/generate-qr");
      const data = await response.json();

      qrImage.src = data.qr;
      qrImage.style.display = "block";
      qrImage.style.opacity = "1";
      qrLoader!.style.display = "none";

      timeLeft = data.expiresIn || 30;
      updateTimerDisplay();
    } catch (error) {
      console.error("Error actualizando QR:", error);
    }
  }

  function updateTimerDisplay() {
    timerElement!.textContent = timeLeft.toString();
    const progress = ((30 - timeLeft) / 30) * 100;
    progressBar!.style.width = `${progress}%`;
  }

  // Intervalo de cuenta regresiva
  setInterval(() => {
    timeLeft--;
    if (timeLeft <= 0) {
      updateQR();
    } else {
      updateTimerDisplay();
    }
  }, 1000);

  // Carga inicial
  updateQR();
</script>
